generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id              Int     @id @default(1)
  name            String?
  title           String?
  bio             String?
  experienceYears Int?
  avatarUrl       String?
  telegram        String?
  linkedin        String?
  github          String?
  email           String?
  phone           String?
}

model Skill {
  id       String  @id @default(uuid())
  name     String
  category String?
  level    Int?    @default(0)
  order    Int     @default(0)
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  imageUrls   String[]
  videoUrl    String?
  liveUrl     String?
  tags        String[]
  date        String?
  order       Int      @default(0)
}

model Education {
  id          String  @id @default(uuid())
  institution String
  degree      String
  startYear   String
  endYear     String?
  description String?
  current     Boolean @default(false)
  order       Int     @default(0)
}

model Workplace {
  id          String  @id @default(uuid())
  company     String
  role        String
  duration    String
  description String?
  imageUrl    String?
  order       Int     @default(0)
}

model Service {
  id          String  @id @default(uuid())
  title       String
  description String
  iconName    String?
  order       Int     @default(0)
}

model Achievement {
  id          String  @id @default(uuid())
  title       String
  description String
  date        String?
  imageUrl    String?
  order       Int     @default(0)
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  message   String
  date      DateTime @default(now())
  read      Boolean  @default(false)
}
